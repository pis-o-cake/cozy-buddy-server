# ── App ─────────────────────────────────────────────────────
APP_NAME=cozy-buddy-server
DEBUG=false
LOG_LEVEL=INFO
DEFAULT_LOCALE=ko

# ── Database (설계서 §6-2) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cozy:cozy@localhost:5432/cozy

# ── Auth (설계서 §11) ───────────────────────────────────────
# 운영 전 반드시 무작위 값으로 교체: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
JWT_EXPIRES_HOURS=24
PAIRING_CODE_TTL_SECONDS=300

# ── LLM (설계서 §3-3, §7-5 — v1은 클라우드 우선) ────────────
# 비우면 키가 구성된 provider를 gemini → openai → anthropic 순으로 자동 선택
LLM_PROVIDER=
# provider별 모델명. 예) anthropic: claude-opus-4-8(고성능) / claude-haiku-4-5(저비용·저지연)
LLM_MODEL=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 로컬 LLM (Phase 4+ — 설계서 §14-2)
LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1

# ── Voice (설계서 §3-3 — 구현체는 Phase 1) ──────────────────
STT_PROVIDER=faster-whisper
STT_MODEL=large-v3-turbo
# IMPORTANT: RTX 5080(Blackwell)은 CTranslate2 INT8 미지원 — float16 고정 (설계서 §3-3)
STT_COMPUTE_TYPE=float16
TTS_PROVIDER=supertonic

# ── IoT (설계서 §8-1 — 구현은 Phase 2) ──────────────────────
IOT_ADAPTERS=kasa,matter
