# CozyBuddy Server 환경 설정
APP_NAME=CozyBuddy
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 데이터베이스
DATABASE_URL=sqlite+aiosqlite:///./cozybuddy.db

# LLM 공통 (클라이언트 미지정 시 기본 프로바이더)
LLM_DEFAULT_PROVIDER=vllm
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# vLLM (로컬 Llama)
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_MODEL=llama-3.1-8b
VLLM_API_KEY=not-needed

# OpenAI (API 키 설정 시 활성화)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Gemini (API 키 설정 시 활성화)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# RAG
RAG_DB_PATH=./data/chromadb
RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# TTS
TTS_MODEL_PATH=./models/piper

# STT
STT_MODEL_SIZE=small
STT_DEVICE=cuda

# 로깅
LOG_LEVEL=INFO
LOG_FILE=logs/cozybuddy.log
